# Copy to .env and fill in. The .env file is read by main.py on startup.
# On Hugging Face, set ANTHROPIC_API_KEY in the Space's Secrets instead.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# MODEL=claude-haiku-4-5          # default; try claude-sonnet-4-6 for top quality
# RATE_LIMIT_SECONDS=300          # one analysis per client per N seconds
# PORT=8000
